# Copy this file to ".env.local" and fill in real values (never commit .env.local).

# --- Quickest local dev (Docker) ---
#   npm run db:quickstart
# That starts MongoDB and writes MONGODB_URI into .env.local if missing.
# Restart `npm run dev` afterward. Same URI works as a manual one-liner:
# MONGODB_URI=mongodb://127.0.0.1:27017/syntraa

# MongoDB Atlas — one line in .env.local. Default database name is "syntraa" unless you override:
# MONGODB_DB_NAME=your_atlas_database_name
# If Atlas still returns "bad auth", try (SCRAM users authenticate against admin):
# MONGODB_AUTH_SOURCE=admin
# After creating .env.local, restart `npm run dev` so Next.js picks it up.
#
# If you see querySrv / ECONNREFUSED on `_mongodb._tcp…`, use the standard mongodb:// string from Atlas
# (Drivers → non-SRV) instead of mongodb+srv:// — skips SRV DNS on broken networks.
# Optional: also accepts MONGO_URI or MONGODB_URL if they hold a mongodb:// or mongodb+srv:// string.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Render / hosts that corrupt `$` inside one line: put the SAME URI but replace USER:PASSWORD with nothing after //
# (host-only), then set user + password separately (encoded automatically):
# MONGODB_URI=mongodb+srv://cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGODB_USER=myAtlasUser
# MONGODB_PASSWORD=my_password
# Or avoid special chars in env: MONGODB_PASSWORD_BASE64=<base64 utf-8 of password>

# Optional: only if unsetting MONGODB_URI — must be mongodb:// or mongodb+srv:// (Postgres DATABASE_URL is ignored).
# DATABASE_URL=mongodb+srv://...

# Hosting (Production): canonical URL — set in Render / Vercel / etc. env (metadataBase & absolute OG URLs).
# Local dev omits this; `layout.tsx` already falls back to https://www.thesyntraa.com
# NEXT_PUBLIC_SITE_URL=https://www.thesyntraa.com


# Default: storefront shows `data/products.js` demos when Atlas has zero products / no URI. Turn off once only Mongo drives the shop:
# SYNTRAA_CATALOG_FALLBACK=false

# Cloudinary (https://console.cloudinary.com → API Keys). Cloud name has no "@" prefix.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional single-line alternative (explicit CLOUDINARY_* above wins when both are set):
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@cloud_name

# --- Admin panel (required on production) ---
# Generate a new random password + hash + session secret:  npm run admin:hash-password
# Copy into `.env.local` or Render → Environment.
ADMIN_EMAIL=admin@syntraa.com
#
# Password `Anushasan123` → bcrypt below. On Render, prefer BASE64 (no `$` — the dashboard often strips `$` from ADMIN_PASSWORD_HASH).
ADMIN_PASSWORD_HASH_BASE64=JDJiJDEyJDNHM3lvMWVCdmtsTUNGSkpNalllNnVad3YxVHMyc1BoekJOeEYwd0IxS2JFZGVaQ2NiNU15
# Local / hosts that keep `$` literally:
# ADMIN_PASSWORD_HASH=$2b$12$3G3yo1eBvklMCFJJMjYe6uZwv1Ts2sPhzBNxF0wB1KbEdeZCcb5My
#
# Production: required — 64 hex chars (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SESSION_SECRET=
#
# Local dev without hash (development only):
# ADMIN_PASSWORD=your-dev-password

# --- Render: admin “all green” checklist ---
# 1) MONGODB_URI + Atlas Network Access (0.0.0.0/0) + DB user password matches URI (or MONGODB_USER + MONGODB_PASSWORD).
# 2) CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET.
# 3) Production: ADMIN_PASSWORD_HASH_BASE64 (or ADMIN_PASSWORD_HASH), ADMIN_SESSION_SECRET.
# 4) After edits: Manual Deploy. Troubleshoot login: GET https://your-site/api/health?admin=1  (shows if hash/session resolve; no secrets).
