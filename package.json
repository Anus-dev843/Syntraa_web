{
  "name": "the-syntraa",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "sync-mockups": "node scripts/sync-mockups-to-public.mjs",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:local-uri": "node scripts/write-local-mongo-uri.mjs",
    "db:quickstart": "npm run db:up && npm run db:local-uri",
    "predev": "npm run sync-mockups",
    "prebuild": "npm run sync-mockups",
    "dev": "next dev",
    "build": "next build",
    "start": "node node_modules/next/dist/bin/next start",
    "start:custom": "node server.mjs",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "admin:hash-password": "node scripts/hash-admin-password.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.10.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.23",
    "mongodb": "^7.2.0",
    "mongodb-connection-string-url": "^7.0.1",
    "mongoose": "^9.6.2",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
